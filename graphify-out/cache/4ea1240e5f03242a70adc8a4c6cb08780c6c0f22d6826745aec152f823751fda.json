ortfolioChart.jsx", "source_location": "L95"}, {"caller_nid": "portfoliochart_portfoliochart", "callee": "(() => {\n    if (pinnedPoint) return pinnedPoint;\n    if (activePoint) return activePoint;\n    if (!chartData.length) return null;\n    const last = chartData[chartData.length - 1];\n    if (mode === 'total') {\n      return {\n        label: last.date,\n        payload: [{ name: 'Total', value: last.Total, color: '#6366f1' }],\n      };\n    }\n    return {\n      label: last.date,\n      payload: accountNames\n        .filter(name => last[name] != null)\n        .map(name => ({ name, value: last[name], color: accountColours[name] || '#6366f1' })),\n    };\n  })", "source_file": "/workspace/investment-dashboard/frontend/src/components/PortfolioChart.jsx", "source_location": "L98"}, {"caller_nid": "portfoliochart_portfoliochart", "callee": "map", "source_file": "/workspace/investment-dashboard/frontend/src/components/PortfolioChart.jsx", "source_location": "L166"}, {"caller_nid": "portfoliochart_portfoliochart", "callee": "map", "source_file": "/workspace/investment-dashboard/frontend/src/components/PortfolioChart.jsx", "source_location": "L180"}, {"caller_nid": "portfoliochart_portfoliochart", "callee": "map", "source_file": "/workspace/investment-dashboard/frontend/src/components/PortfolioChart.jsx", "source_location": "L211"}, {"caller_nid": "portfoliochart_portfoliochart", "callee": "filter", "source_file": "/workspace/investment-dashboard/frontend/src/components/PortfolioChart.jsx", "source_location": "L211"}, {"caller_nid": "portfoliochart_portfoliochart", "callee": "map", "source_file": "/workspace/investment-dashboard/frontend/src/components/PortfolioChart.jsx", "source_location": "L237"}, {"caller_nid": "portfoliochart_portfoliochart", "callee": "reduce", "source_file": "/workspace/investment-dashboard/frontend/src/components/PortfolioChart.jsx", "source_location": "L248"}, {"caller_nid": "portfoliochart_portfoliochart", "callee": "map", "source_file
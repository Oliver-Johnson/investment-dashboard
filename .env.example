# PostgreSQL credentials
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=investment_db

# App token for API authentication (leave blank to disable auth in dev)
APP_TOKEN=

# Trading 212 — ISA account (T212_BASE_URL defaults to live if omitted)
T212_BASE_URL=https://live.trading212.com/api/v0
T212_API_KEY=your_t212_isa_api_key_here
T212_API_SECRET=your_t212_isa_api_secret_here

# Trading 212 — Invest account (T212_INVEST_BASE_URL defaults to live if omitted)
T212_INVEST_BASE_URL=https://live.trading212.com/api/v0
T212_INVEST_API_KEY=your_t212_invest_api_key_here
T212_INVEST_API_SECRET=your_t212_invest_api_secret_here

# eToro
ETORO_API_KEY=your_etoro_public_api_key_here   # Public API Key (from eToro Settings > Trading > API Key Management)
ETORO_USER_KEY=your_etoro_user_key_here        # User Key (the generated key shown after verification)

# Frontend (used as Vite build args)
VITE_APP_TOKEN=
VITE_API_URL=http://localhost:8000

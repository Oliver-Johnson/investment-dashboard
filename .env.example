# PostgreSQL
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=investment_db

# App token for API authentication (leave blank to disable auth in dev)
APP_TOKEN=

# Trading 212
T212_API_KEY=
T212_API_SECRET=
T212_BASE_URL=https://demo.trading212.com/api/v0

# eToro
ETORO_API_KEY=          # Public API Key (from eToro Settings > Trading > API Key Management)
ETORO_USER_KEY=         # User Key (the generated key shown after verification)

# Frontend (used as Vite build args)
VITE_APP_TOKEN=
VITE_API_URL=http://localhost:8000
